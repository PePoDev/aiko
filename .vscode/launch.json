  "version": "0.2.0",
  "configurations": [
    {
      "name": "aiko",
      "type": "dart",
      "request": "launch",
      "toolArgs": ["--dart-define-from-file=.env"]
    },
    {
      "name": "aiko (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "toolArgs": ["--dart-define-from-file=.env"]
    },
    {
      "name": "aiko (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "toolArgs": ["--dart-define-from-file=.env"]
    },
    {
      "name": "Flutter: Run all Tests",
      "type": "dart",
      "request": "launch",
      "program": "./test/",
      "toolArgs": ["--dart-define-from-file=.env"]
    }
  ]
}
